# Session/env state (not source of truth)
.claude/
.mcp.json
*.kicad_prl

# KiCad autosave / lock / backup
~*.lck
_autosave-*
*-backups/

# Diagnostic outputs — regenerated by the toolchain
*_erc.json
*_drc_violations.json

# Freerouting intermediate I/O — regenerated per autoroute run
*.dsn
*.ses

# Scratch dirs — created by workflow tools, not source
logs/
snapshots/
